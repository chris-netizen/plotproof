# Copy to .env.local for local dev. On Vercel, set these in Project Settings > Environment Variables.

# Monad testnet JSON-RPC (server-side only; avoids browser CORS).
PLOTPROOF_RPC_URL=https://testnet-rpc.monad.xyz

# The deployed PlotProof contract.
PLOTPROOF_CONTRACT=0x0e568Fb730D1Ce4b79c9200d516a872C1Aeda6F2

# The block the contract was deployed at — keeps event scans fast.
# Find it: on WSL run
#   grep -i blockNumber ~/plotproof-src/broadcast/Deploy.s.sol/10143/run-latest.json
# (convert the hex to decimal) OR open the contract address on
# testnet.monadexplorer.com and read the creation block.
PLOTPROOF_DEPLOY_BLOCK=0

# eth_getLogs access pattern. Defaults are safe for the PUBLIC RPC
# (testnet-rpc.monad.xyz), which caps getLogs at a 100-block range and
# 25 requests/sec — too slow to index a wide history inside a serverless
# function. For a fast, complete dashboard, point PLOTPROOF_RPC_URL at a
# free dedicated RPC (Alchemy / QuickNode) and raise these:
#   PLOTPROOF_LOG_RANGE=2000
#   PLOTPROOF_RPC_RPS=50
PLOTPROOF_LOG_RANGE=99
PLOTPROOF_CONCURRENCY=8
PLOTPROOF_RPC_RPS=20
